    "@mui/material": "^7.0.0",
    "@mui/x-date-pickers": "^7.23.3",
    "@reduxjs/toolkit": "^2.5.0",
    "@tanstack/react-table": "^8.20.5",
    "async-mutex": "^0.5.0",
    "dayjs": "^1.11.13",
    "idb": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.0.2",
